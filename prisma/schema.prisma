generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum SiteType {
  product
  article
}

enum SiteStatus {
  live
  draft
  archived
}

enum LogType {
  info
  success
  warning
  error
}

enum ImportStatus {
  processing
  completed
  failed
}

enum ImportType {
  xml
  json
}

enum OrderStatus {
  NEW
  PROCESSED
  CANCELLED
}

enum ProductCondition {
  NEW
  USED
  REFURBISHED
  RESERVED
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model ImportBatch {
  id            String       @id @default(uuid())
  name          String
  type          ImportType
  status        ImportStatus @default(processing)
  productsCount Int          @default(0)
  targetSiteIds String[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  products   Product[]
  categories Category[] // <-- Добавлена связь с категориями

  @@map("import_batches")
}

model Category {
  id       String     @id @default(cuid())
  name     String
  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade) // <-- Cascade: удаление родителя удалит детей
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  importBatchId String? // <-- Привязка к импорту
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: Cascade) // <-- Cascade: удаление импорта удалит категории

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id              String                  @id @default(uuid())
  name            String
  slug            String?                  @unique
  subtitle        String?
  standard        String?
  length          String?
  weight          String?
  price           String
  priceUnit       String
  image           String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  externalId      String?                 @unique
  categoryId      String?
  category        Category?               @relation(fields: [categoryId], references: [id], onDelete: Cascade) // <-- Cascade: удаление категории удалит продукты
  quantity        Int                     @default(0)
  characteristics ProductCharacteristic[]

  unit      String           @default("единица")
  condition ProductCondition @default(NEW)

  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  sites      ProductSite[]
  orderItems OrderItem[]
}

model ProductCharacteristic {
  id        String  @id @default(uuid())
  title     String
  value     String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  quantity        Int
  price           String
  name            String
  subtitle        String?
  image           String?
  slug            String?
  unit            String   @default("шт")
  condition       ProductCondition @default(NEW)
  characteristics Json     @default("[]")
}

model ProductSite {
  id          String   @id @default(uuid())
  productId   String
  siteId      String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade) // <-- Cascade: удаление продукта удалит связи с сайтами
  site    Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([productId, siteId])
}

// Остальные модели (Log, Site, Article, ArticleSite, Order) остаются без изменений
model Log {
  id        String   @id @default(uuid())
  type      LogType
  message   String
  timestamp DateTime @default(now())

  @@map("logs")
}

model Site {
  id        String     @id @default(uuid())
  name      String
  domain    String     @unique
  type      SiteType
  status    SiteStatus @default(live)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  articles ArticleSite[]
  products ProductSite[]
}

model Article {
  id        String        @id @default(uuid())
  title     String
  content   String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  sites     ArticleSite[]
}

model ArticleSite {
  id        String   @id @default(uuid())
  articleId String
  siteId    String
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  site    Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([articleId, siteId])
}

model Order {
  id         String      @id @default(cuid())
  email      String
  comment    String?
  status     OrderStatus @default(NEW)
  totalPrice String
  currency   String      @default("RUB")
  items      OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}
